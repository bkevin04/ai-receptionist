# Copy this file to .env and fill in your API keys
# cp .env.example .env

# Vapi AI - Voice AI Platform
VAPI_API_KEY=your_vapi_api_key_here

# Google Calendar Integration
# Set this to the primary email of the calendar you want to use
# Usually: your-email@gmail.com or the shared calendar email
# Also make sure google-credentials.json is in the project root
GOOGLE_CALENDAR_ID=your_calendar_email@gmail.com

# Server Configuration
PORT=3000
